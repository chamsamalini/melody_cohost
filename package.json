{
  "name": "juno-cohost",
  "version": "1.0.0",
  "description": "Juno online meeting co-host voice agent",
  "author": "Juno Co-Host Team",
  "private": true,
  "main": "desktop/main.cjs",
  "type": "module",
  "scripts": {
    "start": "node server.mjs",
    "web:start": "node server.mjs",
    "web:docker:build": "docker build -t juno-cohost:web .",
    "web:docker:run": "docker run --rm -p 8080:8080 --env-file .env juno-cohost:web",
    "check": "node --check server.mjs && node --check public/app.js && node --check desktop/main.cjs",
    "desktop:start": "electron .",
    "desktop:pack:win": "electron-builder --win portable",
    "test:ui": "playwright test",
    "test:ui:headed": "playwright test --headed",
    "test:ui:list": "playwright test --list"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.junocohost.app",
    "productName": "Juno Co-Host",
    "files": [
      "desktop/**",
      "public/**",
      "server.mjs",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": ["portable"],
      "signAndEditExecutable": false,
      "artifactName": "Juno-CoHost-${version}.${ext}"
    }
  }
}
